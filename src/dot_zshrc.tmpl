# shellcheck shell=sh

PATH_DIRS=$(
  cat <<'EOF'
"$HOME/bin"
"$HOME/local/bin"
"$HOME/.local/bin"
"$HOME/.cargo/bin"
EOF
)
{{ if eq .machine.type "wsl" }}
PATH_DIRS="$PATH_DIRS
/mnt/c/Windows/System32/OpenSSH
/mnt/c/Program Files/Microsoft VS Code/bin
/mnt/c/Users/$(whoami)/AppData/Local/Programs/Microsoft VS Code/bin"
{{- end }}

printf '%s\n' "$PATH_DIRS" | while IFS= read -r dir; do
  [ -z "$dir" ] && continue
  case ":$PATH:" in
  *":$dir:"*) ;;
  *) PATH="$PATH:$dir" ;;
  esac
done

# Source all configuration files from ~/.zshrc.d
# This helps keep configurations modular and organized.
# Each configuration should be in a separate file inside ~/.zshrc.d

if [ -d "$HOME/.zshrc.d" ]; then
  for rcfile in "$HOME/.zshrc.d"/*; do
    [ -f "$rcfile" ] && . "$rcfile"
  done
fi
