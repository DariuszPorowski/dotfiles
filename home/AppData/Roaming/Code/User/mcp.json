{
  "inputs": [
    {
      "type": "promptString",
      "id": "CONTEXT7_API_KEY",
      "description": "Context7 API Key",
      "password": true
    }
  ],
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "tools": [
        "*"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
      },
      "tools": [
        "*"
      ]
    },
    "workiq": {
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/workiq",
        "mcp"
      ],
      "tools": [
        "*"
      ]
    }
  }
}
