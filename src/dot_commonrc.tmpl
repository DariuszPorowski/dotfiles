# shellcheck shell=sh

if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    uid=$(id -u)
    dbus-daemon --session --address=unix:path=/run/user/$uid/bus --fork
    export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus"
fi

PATH_DIRS=$(
  cat <<'EOF'
"$HOME/bin"
"$HOME/local/bin"
"$HOME/.local/bin"
"$HOME/.cargo/bin"
EOF
)
{{ if eq .machine.type "wsl" }}
CMD_EXE="/mnt/c/Windows/System32/cmd.exe"
windowsUsername="$($CMD_EXE /c "echo %username%" | tr -d '\r')"

PATH_DIRS="$PATH_DIRS
/mnt/c/Windows/System32/OpenSSH
/mnt/c/Program Files/Microsoft VS Code/bin
/mnt/c/Users/$windowsUsername/AppData/Local/Programs/Microsoft VS Code/bin"
{{- end }}

printf '%s\n' "$PATH_DIRS" | while IFS= read -r dir; do
  [ -z "$dir" ] && continue
  case ":$PATH:" in
  *":$dir:"*) ;;
  *) PATH="$PATH:$dir" ;;
  esac
done

if command -v go &>/dev/null; then
  export GOBIN="$(go env GOPATH)/bin"
fi

if [ -f "$HOME/.local/bin/1p-ssh-agent-relay.sh" ]; then
  "$HOME/.local/bin/1p-ssh-agent-relay.sh"
fi

if [ -f "$HOME/.local/bin/ssh-relay.sh" ]; then
  . "$HOME/.local/bin/ssh-relay.sh"
fi

if command -v aliae >/dev/null 2>&1; then
  # Detect current shell
  _current_shell=$(basename "$SHELL")
  case "$_current_shell" in
    bash|zsh|fish)
      eval "$(aliae init "$_current_shell")"
      ;;
    *)
      # Fallback: try to detect from process name
      if [ -n "$BASH_VERSION" ]; then
        eval "$(aliae init bash)"
      elif [ -n "$ZSH_VERSION" ]; then
        eval "$(aliae init zsh)"
      elif [ -n "$FISH_VERSION" ]; then
        eval "$(aliae init fish)"
      fi
      ;;
  esac
  unset _current_shell
fi

# enable color support of ls and also add handy aliases
if [ -x /usr/bin/dircolors ]; then
  test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
  alias ls='ls --color=auto'
  alias dir='dir --color=auto'
  alias vdir='vdir --color=auto'

  alias grep='grep --color=auto'
  alias fgrep='fgrep --color=auto'
  alias egrep='egrep --color=auto'
fi

# some more ls aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# fnm
FNM_PATH="${HOME}/.local/share/fnm"
if [ -d "$FNM_PATH" ]; then
  export PATH="$FNM_PATH:$PATH"

  # Detect current shell
  _current_shell=$(basename "$SHELL")
  case "$_current_shell" in
    bash|zsh|fish)
      eval "$(fnm env --use-on-cd --version-file-strategy=local --shell "$_current_shell")"
      ;;
    *)
      # Fallback: try to detect from process name
      if [ -n "$BASH_VERSION" ]; then
        eval "$(fnm env --use-on-cd --version-file-strategy=local --shell bash)"
      elif [ -n "$ZSH_VERSION" ]; then
        eval "$(fnm env --use-on-cd --version-file-strategy=local --shell zsh)"
      elif [ -n "$FISH_VERSION" ]; then
        eval "$(fnm env --use-on-cd --version-file-strategy=local --shell fish)"
      fi
      ;;
  esac
  unset _current_shell
fi
