# yaml-language-server: $schema=https://aliae.dev/schema.json
# docs: https://aliae.dev/docs
---
path:
  - value: |
      {{ .Home }}/bin/
      {{ .Home }}/local/bin/
      {{ .Home }}/.local/bin/
      {{ .Home }}/.cargo/bin/
{{- if .machine.wsl }}
  - value: |
      /mnt/c/Windows/System32/OpenSSH
      /mnt/c/Program Files/Microsoft VS Code/bin
      /mnt/c/Users/$windowsUsername/AppData/Local/Programs/Microsoft VS Code/bin
{{- end }}
script:
  - if: and (hasCommand "oh-my-posh.exe") (match .Shell "pwsh")
    value: |
      oh-my-posh init pwsh | Invoke-Expression
  - if: and (hasCommand "oh-my-posh") (match .Shell "bash" "zsh")
    value: |
      eval "$(oh-my-posh init {{ .Shell }})"
